generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id           String   @id @default(uuid())
  cliente_slug String   @unique
  password     String?
  user_id      String?  // Optional para V1, si querés ligarlo a un único admin
  config       String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("clientes_data")
}
